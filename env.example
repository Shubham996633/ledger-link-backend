# Server Configuration
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=password
DB_NAME=ledger_link

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Encryption Configuration
ENCRYPTION_KEY=your-32-character-encryption-key-here

# Blockchain Configuration
DEFAULT_NETWORK=goerli
GOERLI_RPC_URL=https://goerli.infura.io/v3/YOUR_PROJECT_ID
ARBITRUM_GOERLI_RPC_URL=https://goerli-rollup.arbitrum.io/rpc
MAINNET_RPC_URL=https://mainnet.infura.io/v3/YOUR_PROJECT_ID
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc

# Contract Addresses (populated after deployment)
TRANSACTION_LOGGER_CONTRACT=

# Gas Configuration
GAS_LIMIT=500000
GAS_PRICE=20000000000

# API Keys
ETHERSCAN_API_KEY=your-etherscan-api-key
ARBISCAN_API_KEY=your-arbiscan-api-key
PRIVATE_KEY=your-private-key-for-deployment

# External Services
FRONTEND_URL=http://localhost:3000
REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001

# Security
CORS_ORIGIN=http://localhost:3000
HELMET_ENABLED=true

# TODO: Add more environment variables as needed
# TODO: Add production-specific configurations
# TODO: Add staging environment configurations
